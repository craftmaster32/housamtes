# Copy this file to .env and fill in your values
# NEVER commit .env to git — only commit .env.example

EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Expo project ID — find in app.json or expo.dev dashboard
EXPO_PUBLIC_PROJECT_ID=your_expo_project_id_here

# Web push (VAPID) — generate a keypair at: https://web-push-codelab.glitch.me
EXPO_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# Edge Function secrets — set via: supabase secrets set KEY=value
# VAPID_PRIVATE_KEY=your_vapid_private_key_here
# VAPID_CONTACT_EMAIL=housemates32@gmail.com
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Get this from sentry.io → your project → Settings → Client Keys (DSN)
# Leave blank to disable Sentry (it won't run in development regardless)
EXPO_PUBLIC_SENTRY_DSN=
