{
  "expo": {
    "name": "HouseMates",
    "slug": "housemates",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "housemates",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.housemates.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.housemates.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png",
      "display": "standalone",
      "themeColor": "#0D1421",
      "backgroundColor": "#0D1421"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "expo-localization",
      [
        "expo-calendar",
        {
          "calendarPermission": "HouseMates needs calendar access to add house events and parking reservations to your calendar.",
          "remindersPermission": "HouseMates needs reminders access to set due date reminders."
        }
      ]
    ],
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6366f1"
    }
  }
}
