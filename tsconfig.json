{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@components/*": ["components/*"],
      "@hooks/*": ["hooks/*"],
      "@stores/*": ["stores/*"],
      "@types/*": ["types/*"],
      "@constants/*": ["constants/*"],
      "@utils/*": ["utils/*"],
      "@lib/*": ["lib/*"],
      "@locales/*": ["locales/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.d.ts"],
  "exclude": [
    "supabase/functions",
    "HouseMates Design System",
    "HouseMates Design System (2)",
    "handoff",
    "handoff-bills",
    "handoff-parking",
    "handoff-spending",
    "handoff-darkmode"
  ]
}
